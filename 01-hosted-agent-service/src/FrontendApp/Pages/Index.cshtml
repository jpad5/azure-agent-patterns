@page
@model FrontendApp.Pages.IndexModel
@{
    ViewData["Title"] = "Agent Chat";
}

<h1>Agent Chat</h1>
<p>Welcome, <strong>@Model.UserName</strong></p>

<div id="chat-container" style="max-width: 600px;"
     data-agent-url="@Model.AgentServiceBaseUrl"
     data-token="@Model.AccessToken">
    <div id="response-area"
         style="border: 1px solid #ccc; border-radius: 4px; padding: 12px;
                min-height: 120px; margin-bottom: 12px; white-space: pre-wrap;
                background: #f9f9f9; font-family: monospace;">
        <em>Agent responses will appear here.</em>
    </div>

    <form id="chat-form" style="display: flex; gap: 8px;">
        <input type="text" id="prompt-input" placeholder="Ask the agent..."
               style="flex: 1; padding: 8px;" required />
        <button type="submit" id="send-btn" style="padding: 8px 16px;">Send</button>
    </form>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        var container = document.getElementById('chat-container');
        var agentServiceUrl = container.getAttribute('data-agent-url');
        var accessToken = container.getAttribute('data-token');
        var form = document.getElementById('chat-form');
        var input = document.getElementById('prompt-input');
        var responseArea = document.getElementById('response-area');
        var sendBtn = document.getElementById('send-btn');

        responseArea.textContent = 'JS loaded. URL=' + agentServiceUrl + ' Token=' + (accessToken ? accessToken.length + ' chars' : 'EMPTY');

        form.addEventListener('submit', function(e) {
            e.preventDefault();
            var prompt = input.value.trim();
            if (!prompt) return;

            sendBtn.disabled = true;
            responseArea.textContent = 'Sending to ' + agentServiceUrl + '...';

            fetch(agentServiceUrl + '/api/agent/invoke', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'Authorization': 'Bearer ' + accessToken
                },
                body: JSON.stringify({ prompt: prompt })
            })
            .then(function(res) {
                if (!res.ok) {
                    return res.text().then(function(t) {
                        responseArea.textContent = 'Error: ' + res.status + ' ' + res.statusText + '\n' + t;
                    });
                }
                return res.json().then(function(data) {
                    responseArea.textContent =
                        'Agent: ' + data.agentResponse + '\n\nEnterprise API: ' + JSON.stringify(data.enterpriseData, null, 2);
                });
            })
            .catch(function(err) {
                responseArea.textContent = 'Error: ' + err.message;
            })
            .finally(function() {
                sendBtn.disabled = false;
                input.value = '';
            });
        });
    });
</script>
